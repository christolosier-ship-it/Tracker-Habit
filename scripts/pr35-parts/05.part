sub(r'\n    const reset = \(\) => \{\n      gsap\.set\(targets, \{ clearProps: "transform,opacity,visibility" \}\);\n    \};\n', '\n', body)\n    body = re.sub(r'\n    const reset = \(\) => gsap\.set\(targets, \{ clearProps: "transform,opacity,visibility" \}\);\n', '\n', body)\n    body = body.replace("    reset();", "    reset(svg);")\n    body = body.replace("onComplete: reset", "onComplete: () => reset(svg)")\n    target_line = re.search(r"    const targets = .*?;\n", body, re.S)\n    if target_line:\n        pos = target_line.end()\n        body = body[:pos] + "\n    gsap.killTweensOf(targets);\n" + body[pos:]\n    body = body.rstrip() + "\n\n    return timeline;\n"\n    content = f'''import type {{ MascotReaction }} from "../mascot.types";\nimport {{ gsap, type GsapReactionDefinition }} from "../gsap-runtime";\n\nfunction reset(svg: SVGSVGElement) {{\n  gsap.set(svg.querySelectorAll<SVGElement>("[data-gsap]"), {{ clearProps: "transform,opacity,visibility" }});\n  gsap.set(svg.querySelectorAll<SVGElement>("{particle_selector}"), {{\n    clearProps: "transform,opacity,visibility", opacity: 0,\n  }});\n}}\n\nfunction playReaction(svg: SVGSVGElement, reaction: MascotReaction) {{\n{body}\n}}\n\nexport const {slug}Reactions = {{ play: playReaction, reset }} satisfies GsapReactionDefinition;\n'''\n    write(f"src/features/mascot/creatures/{slug}-reactions.ts", content)\n    old.unlink()\n\nfor cap, slug in {\n    "Arcade":"arcade","Aurora":"aurora","Cosmic":"cosmic","Cyberpunk":"cyberpunk",\n    "Dopamine":"dopamine","Kawaii":"kawaii","Memphis":"memphis","Tropical":"tropical",\n}.items():\n    old = creatures / f"use{cap}Reaction.ts"\n    source = old.read_text()\n    source = re.sub(r'import \{ useEffect, type RefObject \} from "react";\n', '', source)\n    source = re.sub(r'import type \{ RefObject \} from "react";\n', '', source)\n    start = source.find("type GsapVars")\n    if start >= 0:\n        markers = [source.find("const transformTargets", start), source.find("const transformTargetSelector", start),\n                   source.find("const animatedSelector", start), source.find("const selector", start), source.find("function reset", start)]\n        end = min(value for value in markers if value >= 0)\n        source = source[:start] + 'import { gsap, type GsapReactionDefinition } from "../gsap-runtime";\n\n' + source[end:]\n    source = re.sub(r'function (?:prefersReducedMotion|reducedMotion)\(\) \{.*?\n\}\n\n', '', source, flags=re.S)\n    source = source.replace("function reset(gsap: GsapApi, root: SVGSVGElement)", "function reset(root: SVGSVGElement)")\n    source = source.replace("function resetAnimatedParts(gsap: GsapApi, root: SVGSVGElement)", "function resetAnimatedParts(root: SVGSVGElement)")\n    source = re.sub(r'function playReaction\(\s*gsap: GsapApi,\s*root: SVGSVGElement,\s*reaction: MascotReaction,?\s*\)',\n                    'function playReaction(root: SVGSVGElement, reaction: MascotReaction)', source, flags=re.S)\n    source = source.replace("function play(gsap: GsapApi, root: SVGSVGElement, reaction: MascotReaction)",\n                            "function playReaction(root: SVGSVGElement, reaction: MascotReaction)")\n    source = source.replace("reset(gsap, root)", "reset(root)").replace("resetAnimatedParts(gsap, root)", "resetAnimatedParts(root)")\n    hook = re.search(r'\nexport function use\w+Reaction\([\s\S]*$', source)\n    if not hook:\n        raise RuntimeError(f"Hook ending not found in {old}")\n    reset_name = "resetAnimatedParts" if "function resetAnimatedParts" in source else "reset"\n    source = source[:hook.start()] + f'\n\nexport const {slug}Reactions = {{ play: playReaction, reset: {reset_name} }} satisfies GsapReactionDefinition;\n'\n    write(f"src/features/mascot/creatures/{slug}-reactions.ts", source)\n    old.unlink()\n\nfor cap, slug in {\n    "Arcade":"arcade","Aurora":"aurora","Brutalist":"brutalist","Comic":"comic","Cosmic":"cosmic","Cyberpunk":"cyberpunk",\n    "Dopamine":"dopamine","Editorial":"editorial","Kawaii":"kawaii","Liquid":"liquid","Memphis":"memphis","Tropical":"tropical",\n}.items():\n    component = creatures / f"{cap}Mascot.tsx"\n    source = component.read_text()\n    source = source.replace(f'import {{ use{cap}Reaction }} from "./use{cap}Reaction";',\n                            f'import {{ {slug}Reactions }} from "./{slug}-reactions";\nimport {{ useGsapReactionRuntime }} from "../gsap-runtime";')\n    source = source.replace("({ mood, reaction }: MascotCreatureProps)",\n                            "({ mood, reaction, onReactionComplete }: MascotCreatureProps)")\n    source = re.sub(rf'use{cap}Reaction\(svgRef, reaction \?\? null\);',\n                    f'useGsapReactionRuntime(\n    svgRef, reaction ?? null, {slug}Reactions.play, {slug}Reactions.reset, onReactionComplete,\n  );', source)\n    component.wri